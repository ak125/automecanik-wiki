{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ak125/automecanik-wiki/_meta/schema/exports-seo.schema.json",
  "title": "automecanik-wiki exports/seo/ contract v1.1.0",
  "description": "Schema strict pour wiki/exports/seo/<entity_type>/<slug>.json. Vue dérivée éphémère du wiki canon. Référence : ADR-059 SEO Runtime Projection §Décision (accepted 2026-05-13). v1.1.0 (ADR-086, 2026-06-13) : blocks portent source_ids[] préfixés + truth_level + usefulness_target — le canon WIKI structuré (entity_data.dimensions/decision_brief/maintenance/related_parts) est projeté en facts/blocks role-aware.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "entity_type",
    "schema_version",
    "projection_contract_version",
    "source_wiki_commit",
    "wiki_path",
    "content_hash",
    "generated_at",
    "facts",
    "sources",
    "blocks",
    "roles_allowed",
    "consumers_allowed"
  ],
  "properties": {
    "entity_id": {
      "type": "string",
      "pattern": "^(gamme|vehicle|constructeur|diagnostic):[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "URN-style id <entity_type>:<slug>. Match frontmatter wiki canon."
    },
    "entity_type": {
      "type": "string",
      "enum": ["gamme", "vehicle", "constructeur", "diagnostic"],
      "description": "support EXCLU per ADR-059 — routé vers exports/support/, pas exports/seo/."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version du contrat JSON export (couche transport). Distinct de projection_contract_version."
    },
    "projection_contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version du contrat runtime DB (runner + RPC + pages). Distinct de schema_version. assertCompatibleProjectionContract() vérifie compatibilité au runner."
    },
    "source_wiki_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,64}$",
      "description": "Git commit SHA du wiki canon source. INFORMATIONAL-ONLY audit metadata per ADR-059. Replay authority = exports_snapshot_hash (couche projection)."
    },
    "wiki_path": {
      "type": "string",
      "pattern": "^wiki/(gamme|vehicle|constructeur|diagnostic)/[a-z0-9][a-z0-9-]*[a-z0-9]\\.md$",
      "description": "Chemin relatif wiki/<entity_type_singular>/<slug>.md per ADR-031 §148. support exclu."
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "sha256 du fichier wiki canon source (frontmatter + body), avant transformation."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "builder_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "source_id": { "type": ["string", "null"] }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["specialist", "specialized_reference", "consulting", "commercial", "engineer", "oem", "manual", "web", "recycled"]
          },
          "url": { "type": ["string", "null"] }
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content_md", "source_ids", "truth_level"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["R0_HOME", "R1_ROUTER", "R2_PRODUCT", "R3_CONSEILS", "R4_REFERENCE", "R6_GUIDE_ACHAT", "R7_BRAND", "R8_VEHICLE"]
          },
          "section": { "type": ["string", "null"] },
          "content_md": { "type": "string", "minLength": 1 },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "pattern": "^(db|web|raw|oem|specialist):" },
            "description": "PRÉFIXÉS db:<table> | web:<evidence_id> | raw:<path> — sépare DB-owned de sourced (ADR-086). Vide autorisé si truth_level=db_owned ET role identitaire."
          },
          "truth_level": {
            "type": "string",
            "enum": ["db_owned", "sourced", "inferred", "editorial"],
            "description": "ADR-086 : db_owned (DB) | sourced (web/oem) | inferred (dérivé) | editorial (reformulé)."
          },
          "usefulness_target": { "type": ["string", "null"] }
        }
      }
    },
    "roles_allowed": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["R0_HOME", "R1_ROUTER", "R2_PRODUCT", "R3_CONSEILS", "R4_REFERENCE", "R6_GUIDE_ACHAT", "R7_BRAND", "R8_VEHICLE"]
      },
      "description": "minItems:1 STRICT : un export sans rôle SEO doit aller dans exports/support/, pas exports/seo/."
    },
    "consumers_allowed": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["seo", "rag", "support", "diagnostic_tool"]
      }
    }
  }
}
